# ── Ganado Cloud API ──────────────────────────────────────────
CLOUD_API_URL=https://ganado.gpcb.com.co/api/v1
DEVICE_ID=<uuid-from-register-endpoint>
DEVICE_API_KEY=<api-key-from-register-endpoint>

# ── Rice Lake 920i Scale ─────────────────────────────────────
SCALE_HOST=192.168.1.200
SCALE_PORT=10001
SCALE_PROTOCOL=tcp
# SCALE_SERIAL_PORT=/dev/ttyUSB0
# SCALE_BAUD_RATE=9600

# ── RFID Reader ──────────────────────────────────────────────
RFID_SERIAL_PORT=/dev/ttyUSB1
RFID_BAUD_RATE=57600
RFID_PROTOCOL=serial
# RFID_TCP_HOST=192.168.1.201
# RFID_TCP_PORT=4001

# ── UniFi Protect Camera ────────────────────────────────────
UNIFI_HOST=192.168.1.1
UNIFI_USERNAME=admin
UNIFI_PASSWORD=password
UNIFI_CAMERA_ID=<camera-uuid>

# ── WebSocket (browser UI) ───────────────────────────────────
WS_PORT=8765

# ── Offline Queue ────────────────────────────────────────────
QUEUE_DB_PATH=./data/offline-queue.sqlite
SYNC_INTERVAL_MS=30000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
