# ============================================================
# Ganado App — Shared Infrastructure Environment Variables
# ============================================================
# Copy this file to .env and fill in the values before deploying.

ENVIRONMENT=production
BASE_PATH=/srv

# --- Shared Redis ---
GANADO_REDIS_PASSWORD=CHANGE_ME_strong_redis_password
GANADO_REDIS_PORT_EXTERNAL=6380

# --- Host PostgreSQL Connection ---
# These point to the EXISTING PostgreSQL 17 on the host.
# The deploy script will create the databases and users.
PG_HOST=host.docker.internal
PG_PORT=5432
PG_ADMIN_USER=postgres
PG_ADMIN_PASSWORD=CHANGE_ME_pg_admin_password

# --- Ganado App Database ---
GANADO_DB_NAME=ganado_app
GANADO_DB_USER=ganado_app_user
GANADO_DB_PASSWORD=CHANGE_ME_ganado_db_password
GANADO_DB_SCHEMA=public
GANADO_DB_MAX_CONNECTIONS=50
GANADO_DB_IDLE_TIMEOUT=10000

# --- ChirpStack Database ---
GANADO_CS_DB_NAME=ganado_chirpstack
GANADO_CS_DB_USER=ganado_cs_user
GANADO_CS_DB_PASSWORD=CHANGE_ME_chirpstack_db_password

# --- Ganado Backend ---
GANADO_BACKEND_PORT=3100
GANADO_CORS_ORIGINS=https://ganado.yourdomain.com
GANADO_CORS_ALLOWED_LOCAL=
GANADO_JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_chars
GANADO_JWT_EXPIRATION=24h
GANADO_JWT_REFRESH_EXPIRATION=7d

# --- Ganado Frontend ---
GANADO_FRONTEND_PORT=8180
GANADO_API_BASE_URL=https://ganado.yourdomain.com/api/v1
GANADO_BACKEND_URL=http://ganado_backend:3000

# --- ChirpStack ---
GANADO_CS_PORT=8180
GANADO_CS_REST_API_PORT=8190
GANADO_CS_BRIDGE_PORT=1700
GANADO_CS_BRIDGE_BS_PORT=3101
GANADO_CS_MOSQUITTO_PORT=1884

# --- MQTT (Ganado backend → ChirpStack Mosquitto) ---
GANADO_MQTT_BROKER_URL=mqtt://ganado_mosquitto:1883
GANADO_MQTT_BROKER_HOST=ganado_mosquitto
GANADO_MQTT_BROKER_PORT=1883
GANADO_MQTT_BROKER_PROTOCOL=mqtt

# --- ChirpStack API (Ganado backend → ChirpStack) ---
GANADO_CS_API_URL=http://ganado_chirpstack:8080
GANADO_CS_API_KEY=CHANGE_ME_chirpstack_api_key

# --- Domain ---
GANADO_DOMAIN=ganado.yourdomain.com
